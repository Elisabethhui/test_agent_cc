# 创建 .gitignore
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 配置文件（如果包含敏感信息）
*.env
config.local.py

# 日志和数据库
*.log
*.sqlite
*.db

# 模型文件（通常很大）
*.pth
*.pt
*.bin
*.onnx
*.h5

# 测试和临时文件
.pytest_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/
EOF

# 将 .gitignore 添加到 Git
git add .gitignore
git commit -m "Add .gitignore"